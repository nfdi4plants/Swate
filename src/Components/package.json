{
  "name": "@nfdi4plants/swate-components",
  "version": "0.0.0",
  "description": "Customizable React components for ontology annotation, based on Swate and the ARC.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/assets/swate-components.css"
  },
  "scripts": {
    "clean": "dotnet fable clean -e fs.ts --yes",
    "fable": "dotnet fable ./src/Swate.Components.fsproj --lang ts",
    "start": "npm run fable -- --watch --run vite",
    "dev": "npm run start",
    "test": "npm run clean && npm run fable -- --watch --run npx vitest --project=storybook",
    "test:run": "npm run clean && npm run fable -- --noCache && npx vitest run --project=storybook",
    "prelink": "npm run build",
    "storybook": "npm run fable -- --watch --run storybook dev -p 6006",
    "storybook:no-compile": "storybook dev -p 6006",
    "prebuild:net": "npx @tailwindcss/cli -i ./tailwind.css -o ./src/swate-components.css -m",
    "build": "npm run clean && npm run fable -- --fableLib @fable-org/fable-library-ts --noCache -e fs.ts -o ./src/dist && vite build",
    "build:net": "dotnet pack ./src/Swate.Components.fsproj",
    "prebuild:storybook": "npm run fable -- --noCache",
    "build:storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nfdi4plants/Swate.git"
  },
  "keywords": [
    "rdm",
    "ontology",
    "term",
    "react"
  ],
  "author": "Kevin Frey <freymaurer@gmx.de>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nfdi4plants/Swate/issues"
  },
  "homepage": "https://github.com/nfdi4plants/Swate#readme",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fable-org/fable-library-ts": "^2.2.0",
    "@floating-ui/react": "^0.27.15",
    "@nfdi4plants/arctrl": "^3.0.0-alpha.4",
    "@tanstack/react-virtual": "^3.13.2",
    "@uidotdev/usehooks": "^2.4.1",
    "@uiw/react-markdown-preview": "^5.1.4",
    "@uiw/react-md-editor": "^4.0.11",
    "fuse.js": "^7.1.0",
    "mammoth": "^1.10.0",
    "mermaid": "^11.12.3",
    "rehype-rewrite": "^4.0.4",
    "rehype-sanitize": "^6.0.0",
    "pdfjs-dist": "^5.4.449",
    "react-highlight-words": "^0.20.0",
    "react-pdf": "^9.2.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
