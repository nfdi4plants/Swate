<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Swate.Components</PackageId>
    <PackageVersion>0.0.0</PackageVersion>
    <Authors>Kevin Frey</Authors>
    <Description>Swate react components</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>F# fable rdm react fable-library fable-javascript</PackageTags>
    <PackageProjectUrl>https://github.com/nfdi4plants/Swate</PackageProjectUrl>
    <RepositoryUrl>https://github.com/nfdi4plants/Swate</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ARCtrl.Core" />
    <PackageReference Include="ARCtrl.Spreadsheet" />
    <PackageReference Include="Fable.Remoting.Client" />
    <PackageReference Include="Fable.Fetch" />
    <PackageReference Include="Fable.React.Types" />
    <PackageReference Include="Fable.Core" />
    <PackageReference Include="Feliz" />
    <PackageReference Include="Fable.Browser.Dom" />
  </ItemGroup>

  <ItemGroup>
    <!-- Include all files that are compiled with this project -->
    <!-- Include the project file itself as well -->
    <Content Include="$(MSBuildThisFileFullPath)" Pack="true" PackagePath="fable/" />
    <Content Include="..\package.json">
      <Link>package.json</Link>
    </Content>
    <Content Include="..\tailwind.css">
      <Link>tailwind.css</Link>
    </Content>
    <Content Include="..\tsconfig.json">
      <Link>tsconfig.json</Link>
    </Content>
    <Content Include="..\vite.config.mts">
      <Link>vite.config.mts</Link>
    </Content>
    <TypeScriptCompile Include="..\vitest.config.ts">
      <Link>vitest.config.ts</Link>
    </TypeScriptCompile>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\Swate.Components.Core.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
    <None Include="swateBundleStyle.css" Pack="true" PackagePath="fable/" />
    <Compile Include="Util\Types.fs" />
    <Compile Include="Util\Virtual.fs" />
    <Compile Include="Util\FloatingUI.fs" />
    <Compile Include="Util\Constants.fs" />
    <Compile Include="Util\Extensions.fs" />
    <Compile Include="Util\React.useListener.fs" />
    <Compile Include="Util\ARCtrl.Helper.fs" />
    <Compile Include="Util\ReactContexts.fs" />
    <Compile Include="Api\Helper.fs" />
    <Compile Include="Api\SwateApi.fs" />
    <Compile Include="Api\GitLabApi.fs" />
    <Compile Include="Api\TIBApi.fs" />
    <Compile Include="GenericComponents\Icons.fs" />
    <Compile Include="GenericComponents\GenericComponents.fs" />
    <Compile Include="GenericComponents\ContextMenu.fs" />
    <Compile Include="GenericComponents\BaseModal.fs" />
    <Compile Include="GenericComponents\Select.fs" />
    <Compile Include="GenericComponents\ComboBox.fs" />
    <Compile Include="GenericComponents\CardGrid.fs" />
    <Compile Include="GenericComponents\Dropdown.fs" />
    <Compile Include="GenericComponents\Actionbar.fs" />
    <Compile Include="GenericComponents\Navbar.fs" />
    <Compile Include="ARCSelector\Types.fs" />
    <Compile Include="ARCSelector\Selector.fs" />
    <Compile Include="Layout\Layout.fs" />
    <Compile Include="FileExplorer\FileTreeDataStructures.fs" />
    <Compile Include="FileExplorer\FileExplorerGitLfsHelper.fs" />
    <Compile Include="FileExplorer\FileExplorerBreadcrumbs.fs" />
    <Compile Include="FileExplorer\FileExplorer.fs" />
    <Compile Include="ThemeProvider\ThemeProvider.fs" />
    <Compile Include="QuickAccessButton\QuickAccessButton.fs" />
    <Compile Include="TermSearch\TermSearchConfigProvider.fs" />
    <Compile Include="TermSearch\TermSearchConfigSetter.fs" />
    <Compile Include="TermSearch\TermSearch.fs" />
    <Compile Include="Metadata\Generic.fs" />
    <Compile Include="Metadata\TextInput.fs" />
    <Compile Include="Metadata\JsBindings\DndKit.fs" />
    <Compile Include="Metadata\Forms.fs" />
    <Compile Include="MarkdownText\Types.fs" />
    <Compile Include="MarkdownText\JsBindings\ReactMDEditor.fs" />
    <Compile Include="MarkdownText\JsBindings\Mermaid.fs" />
    <Compile Include="MarkdownText\Plugins\PluginTypes.fs" />
    <Compile Include="MarkdownText\Plugins\AddStep.fs" />
    <Compile Include="MarkdownText\Plugins\AddImage.fs" />
    <Compile Include="MarkdownText\Plugins\AddOntologyReference.fs" />
    <Compile Include="MarkdownText\Plugins\PluginRegistry.fs" />
    <Compile Include="MarkdownText\Plugins\PluginTextInputHelpers.fs" />
    <Compile Include="MarkdownText\Plugins\MarkdownPluginPromptModal.fs" />
    <Compile Include="MarkdownText\Preview.fs" />
    <Compile Include="MarkdownText\TextInputWithMarkdown.fs" />
    <Compile Include="Landing\Types.fs" />
    <Compile Include="Landing\State.fs" />
    <Compile Include="Landing\Validation.fs" />
    <Compile Include="Landing\Conversion.fs" />
    <Compile Include="Landing\SharedFields.fs" />
    <Compile Include="Landing\StudySection.fs" />
    <Compile Include="Landing\AssaySection.fs" />
    <Compile Include="Landing\TargetSelector.fs" />
    <Compile Include="Landing\Actions.fs" />
    <Compile Include="Landing\Landing.fs" />
    <Compile Include="Template\TemplateFilter.fs" />
    <Compile Include="Table\KeyboardNavigation.fs" />
    <Compile Include="Table\TableCell.fs" />
    <Compile Include="Table\Table.fs" />
    <Compile Include="AnnotationTable\AnnotationTableContextMenu.fs" />
    <Compile Include="AnnotationTable\AnnotationTableModals.fs" />
    <Compile Include="AnnotationTable\AnnotationTableContextProvider.fs" />
    <Compile Include="AnnotationTable\AnnotationTable.fs" />
    <Compile Include="DataMapTable\DataMapTable.fs" />
    <Compile Include="Widgets\LocalStorage.fs" />
    <Compile Include="Widgets\Widgets.fs" />
    <Compile Include="Widgets\WidgetSupport.fs" />
    <Compile Include="Widgets\BuildingBlockWidget.fs" />
    <Compile Include="Widgets\FilePickerWidget.fs" />
    <Compile Include="Widgets\DataAnnotatorWidget.fs" />
    <Compile Include="Widgets\TemplateWidget.fs" />
    <Compile Include="Notes\Types.fs" />
    <Compile Include="Notes\NoteSearch\NoteSearchComponent.fs" />
    <Compile Include="Notes\Editor\Types.fs" />
    <Compile Include="Notes\Editor\State.fs" />
    <Compile Include="Notes\Editor\Validation.fs" />
    <Compile Include="Notes\Editor\Conversion.fs" />
    <Compile Include="Notes\Editor\NoteFormFields.fs" />
    <Compile Include="Notes\Editor\TargetSelector.fs" />
    <Compile Include="Notes\Editor\Actions.fs" />
    <Compile Include="Notes\Editor\Notes.fs" />
    <Compile Include="DataHub\Types.fs" />
    <Compile Include="DataHub\MockData.fs" />
    <Compile Include="DataHub\GenericComponents.fs" />
    <Compile Include="DataHub\DataHubBrowser.fs" />
    <Compile Include="DataHub\DataHubSidebar.fs" />
    <Compile Include="Authentication\Types.fs" />
    <Compile Include="Authentication\AccountManager.fs" />
    <Compile Include="Authentication\Authentication.fs" />
    <Compile Include="Style.fs" />
  </ItemGroup>

  <PropertyGroup>
    <NpmDependencies>
      <NpmPackage Name="@floating-ui/react" Version="gte 0.27.7 lt 1.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="@dnd-kit/core" Version="gte 6.3.0 lt 7.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="@dnd-kit/sortable" Version="gte 10.0.0 lt 11.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="@dnd-kit/utilities" Version="gte 3.2.0 lt 4.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="@uiw/react-md-editor" Version="gte 4.0.0 lt 5.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="@uiw/react-markdown-preview" Version="gte 5.0.0 lt 6.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="mermaid" Version="gte 11.0.0 lt 12.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="rehype-rewrite" Version="gte 4.0.0 lt 5.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="rehype-sanitize" Version="gte 6.0.0 lt 7.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="@tanstack/react-virtual" Version="gte 3.0.0 lt 4.0.0" ResolutionStrategy="Max" />
      <NpmPackage Name="@uidotdev/usehooks" Version="gte 2.0.0 lt 3.0.0" ResolutionStrategy="Max" />
    </NpmDependencies>
  </PropertyGroup>

</Project>
