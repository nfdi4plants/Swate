    <Compile Include="Composites\AnnotationTable\AnnotationTable.fs"/>
    <Compile Include="Composites\DataMapTable\DataMapTable.fs"/>
    <Compile Include="Composites\Authentication\Types.fs"/>
    <Compile Include="Composites\Authentication\Helper.fs"/>
    <Compile Include="Composites\Authentication\AccountManager.fs"/>
    <Compile Include="Composites\Authentication\Authentication.fs"/>
    <Compile Include="Composites\ArcSelector\ArcSelector.fs"/>
    <Compile Include="Composites\ArcVaultActions\ArcVaultActions.fs"/>
    <Compile Include="Composites\MarkdownText\JsBindings\Mermaid.fs"/>
    <Compile Include="Composites\MarkdownText\JsBindings\ReactMDEditor.fs"/>
