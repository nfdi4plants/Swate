    <Compile Include="Composites\ThemeSelector\ThemeSelector.fs"/>
    <Compile Include="Composites\TermSearch\Context\ActiveKeysContext.fs"/>
    <Compile Include="Composites\TermSearch\Context\AllKeysContext.fs"/>
    <Compile Include="Composites\TermSearch\Context\ConfigContext.fs"/>
