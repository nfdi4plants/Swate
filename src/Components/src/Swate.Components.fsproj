<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <DefineConstants>FABLE_COMPILER</DefineConstants>
    <!-- DefineConstants is required to hotfix an ARCtrl issue, remove if the issue below is resolved and ARCtrl is updated to a version that fixes it -->
    <!-- https://github.com/nfdi4plants/ARCtrl/issues/603 -->
    <DefineConstants>FABLE_COMPILER_JAVASCRIPT</DefineConstants>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Swate.Components</PackageId>
    <PackageVersion>0.0.0</PackageVersion>
    <Authors>Kevin Frey</Authors>
    <Description>Swate react components</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>F# fable rdm react fable-library fable-javascript</PackageTags>
    <PackageProjectUrl>https://github.com/nfdi4plants/Swate</PackageProjectUrl>
    <RepositoryUrl>https://github.com/nfdi4plants/Swate</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="YAMLicious" />
    <PackageReference Include="ARCtrl.Core" />
    <PackageReference Include="ARCtrl.Javascript" />
    <PackageReference Include="ARCtrl.Spreadsheet" />
    <PackageReference Include="Fable.Remoting.Client" />
    <PackageReference Include="Fable.Fetch" />
    <PackageReference Include="Fable.React.Types" />
    <PackageReference Include="Fable.Core" />
    <PackageReference Include="Feliz" />
    <PackageReference Include="Feliz.UseElmish" />
    <PackageReference Include="Fable.Browser.Dom" />
  </ItemGroup>

  <ItemGroup>
    <!-- Include all files that are compiled with this project -->
    <!-- Include the project file itself as well -->
    <Content Include="$(MSBuildThisFileFullPath)" Pack="true" PackagePath="fable/" />
    <Content Include="..\package.json">
      <Link>package.json</Link>
    </Content>
    <Content Include="..\tailwind.css">
      <Link>tailwind.css</Link>
    </Content>
    <Content Include="..\tsconfig.json">
      <Link>tsconfig.json</Link>
    </Content>
    <Content Include="..\vite.config.mts">
      <Link>vite.config.mts</Link>
    </Content>
    <TypeScriptCompile Include="..\vitest.config.ts">
      <Link>vitest.config.ts</Link>
    </TypeScriptCompile>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Shared\Swate.Components.Core.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
    <None Include="swateBundleStyle.css" Pack="true" PackagePath="fable/" />
    <Compile Include="Util\Types.fs" />
    <Compile Include="Util\DateTimeExtensions.fs" />
    <Compile Include="Util\Extensions.fs" />
    <Compile Include="Util\React.useListener.fs" />
    <Compile Include="JsBindings\Virtual.fs" />
    <Compile Include="JsBindings\FloatingUI.fs" />
    <Compile Include="JsBindings\DndKit.fs" />
    <Compile Include="ARCtrl\TermCollection.fs" />
    <Compile Include="ARCtrl\Helper.fs" />
    <Compile Include="ARCtrl\ArcIO.fs" />
    <Compile Include="ARCtrl\Types\CompositeCellDiscriminate.fs" />
    <Compile Include="ARCtrl\Types\CompositeHeaderDiscriminate.fs" />
    <Compile Include="ARCtrl\ArcTable.fs" />
    <Compile Include="ARCtrl\Extensions\OntologyAnnotation.fs" />
    <Compile Include="ARCtrl\Extensions\CompositeHeader.fs" />
    <Compile Include="ARCtrl\Extensions\CompositeCell.fs" />
    <Compile Include="ARCtrl\Extensions\ArcTable.fs" />
    <Compile Include="ARCtrl\Extensions\DataFile.fs" />
    <Compile Include="ARCtrl\Extensions\DataMap.fs" />
    <Compile Include="ARCtrl\Extensions\Template.fs" />
    <Compile Include="Api\Helper.fs" />
    <Compile Include="Api\SwateApi.fs" />
    <Compile Include="Api\GitLabApi.fs" />
    <Compile Include="Api\TIBApi.fs" />
   
    <Compile Include="Primitives\Types.fs" />
