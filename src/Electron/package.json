{
  "name": "swate",
  "productName": "Swate",
  "version": "2.0.0-alpha.4",
  "description": "An open-source, cross-platform, and user-friendly software for managing and sharing scientific data.",
  "main": ".vite/build/main.fs.js",
  "config": {
    "forge": "./forge.config.js"
  },
  "scripts": {
    "fable": "dotnet fable ./src/Swate.Electron.fsproj -o ./src/fable_output -e fs.jsx --verbose",
    "fable:watch": "npm run fable -- --watch",
    "start": "npm run fable -- --watch --run electron-forge start",
    "start:e": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "npm run fable && electron-forge publish",
    "publish:dry-run": "npm run fable && electron-forge publish --dry-run",
    "publish:from-dry-run": "electron-forge publish --from-dry-run",
    "test:e2e": "playwright test"
  },
  "keywords": [],
  "author": {
    "name": "Kevin F",
    "email": "Freymaurer@gmx.de"
  },
  "license": "MIT",
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "simple-git": "^3.32.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "electron": "40.10.2"
  }
}
